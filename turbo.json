{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "concurrency": "20",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint",
        "^build"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types",
        "^build"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "outputs": [
        "coverage/**"
      ],
      "dependsOn": [
        "^build"
      ],
      "cache": true
    },
    "//#knip:check": {
      "cache": true,
      "inputs": [
        "**/*.ts",
        "**/*.tsx",
        "package.json",
        "knip.json",
        "**/package.json"
      ]
    }
  }
}
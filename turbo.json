{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "concurrency": "20",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint",
        "^build"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types",
        "^build"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "outputs": [
        "coverage/**"
      ],
      "dependsOn": [
        "^build"
      ],
      "cache": true
    },
    "//#knip:check": {
      "cache": true,
      "inputs": [
        "**/*.ts",
        "**/*.tsx",
        "package.json",
        "knip.json",
        "**/package.json"
      ]
    },
    "docs:generate": {
      "cache": false
    },
    "docs#docs:generate": {
      "dependsOn": [
        "@ai-billing/core#docs:generate",
        "@ai-billing/polar#docs:generate",
        "@ai-billing/openmeter#docs:generate",
        "@ai-billing/lago#docs:generate",
        "@ai-billing/stripe#docs:generate",
        "@ai-billing/openrouter#docs:generate",
        "@ai-billing/openai#docs:generate",
        "@ai-billing/openai-compatible#docs:generate",
        "@ai-billing/groq#docs:generate",
        "@ai-billing/gateway#docs:generate",
        "@ai-billing/google#docs:generate",
        "@ai-billing/anthropic#docs:generate"
      ],
      "cache": false
    }
  }
}
{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreDependencies": [
    "next",
    "tsup",
    "eslint-plugin-jsdoc",
    "eslint-plugin-tsdoc",
    "typedoc-plugin-markdown"
  ],
  "ignore": [
    "examples/utils/**",
    "examples/chatbot-gateway-with-billing-polar-advanced/**",
    "examples/chatbot-gateway-with-billing-stripe-advanced/**",
    "examples/chatbot-openai-with-billing-polar-advanced/**",
    "examples/chatbot-with-billing/**",
    "apps/storybook/**"
  ],
  "workspaces": {
    "packages/nextjs": {
      "ignoreDependencies": [
        "@ai-billing/anthropic",
        "@ai-billing/chutes",
        "@ai-billing/deepseek",
        "@ai-billing/gateway",
        "@ai-billing/google",
        "@ai-billing/groq",
        "@ai-billing/minimax",
        "@ai-billing/openai",
        "@ai-billing/openrouter",
        "@ai-billing/xai",
        "@ai-sdk/anthropic",
        "@ai-sdk/deepseek",
        "@ai-sdk/google",
        "@ai-sdk/groq",
        "@ai-sdk/openai",
        "@ai-sdk/openai-compatible",
        "@ai-sdk/xai",
        "@openrouter/ai-sdk-provider"
      ]
    }
  }
}

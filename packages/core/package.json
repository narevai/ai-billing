{
    "name": "@ai-billing/core",
    "version": "0.0.1",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./stripe": {
            "types": "./dist/stripe/index.d.ts",
            "import": "./dist/stripe/index.js",
            "require": "./dist/stripe/index.cjs"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "devDependencies": {
        "tsup": "^8.3.0",
        "typescript": "5.8.3",
        "vitest": "^4.1.1"
    }
}
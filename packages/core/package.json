{
    "name": "@ai-billing/core",
    "version": "0.0.1",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        },
        "./stripe": {
            "import": {
                "types": "./dist/stripe/index.d.ts",
                "default": "./dist/stripe/index.js"
            },
            "require": {
                "types": "./dist/stripe/index.d.cts",
                "default": "./dist/stripe/index.cjs"
            }
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "devDependencies": {
        "tsup": "^8.3.0",
        "typescript": "5.8.3",
        "vitest": "^4.1.1"
    }
}
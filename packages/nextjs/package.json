{
  "name": "@ai-billing/nextjs",
  "version": "0.0.10",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/narevai/ai-billing.git",
    "directory": "packages/nextjs"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      },
      "require": {
        "types": "./dist/server.d.cts",
        "default": "./dist/server.cjs"
      }
    },
    "./server-action": {
      "import": {
        "types": "./dist/chat/server-actions.d.ts",
        "default": "./dist/chat/server-actions.js"
      },
      "require": {
        "types": "./dist/chat/server-actions.d.cts",
        "default": "./dist/chat/server-actions.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "oxlint",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs:generate": "typedoc --options typedoc.json",
    "prepack": "node -e \"require('fs').copyFileSync('../../LICENSE', 'LICENSE')\"",
    "postpack": "node -e \"require('fs').rmSync('LICENSE', { force: true })\""
  },
  "dependencies": {
    "@ai-billing/anthropic": "workspace:*",
    "@ai-billing/chutes": "workspace:*",
    "@ai-billing/core": "workspace:*",
    "@ai-billing/deepseek": "workspace:*",
    "@ai-billing/gateway": "workspace:*",
    "@ai-billing/google": "workspace:*",
    "@ai-billing/groq": "workspace:*",
    "@ai-billing/minimax": "workspace:*",
    "@ai-billing/narev": "workspace:*",
    "@ai-billing/openai": "workspace:*",
    "@ai-billing/openrouter": "workspace:*",
    "@ai-billing/polar": "workspace:*",
    "@ai-billing/types": "workspace:*",
    "@ai-billing/ui": "workspace:*",
    "@ai-billing/xai": "workspace:*",
    "@ai-sdk/anthropic": "^3.0.0",
    "@ai-sdk/deepseek": "^2.0.0",
    "@ai-sdk/google": "^3.0.0",
    "@ai-sdk/groq": "^3.0.0",
    "@ai-sdk/openai": "catalog:",
    "@ai-sdk/openai-compatible": "^2.0.0",
    "@ai-sdk/react": "^3.0.0",
    "@ai-sdk/rsc": "^2.0.0",
    "@ai-sdk/xai": "^3.0.0",
    "@openrouter/ai-sdk-provider": "catalog:",
    "ai": "catalog:"
  },
  "devDependencies": {
    "@ai-billing/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "oxlint": "catalog:",
    "typedoc": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": "^18 || ^19"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

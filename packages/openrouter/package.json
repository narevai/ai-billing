{
  "name": "@ai-billing/openrouter",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/narevai/ai-billing.git",
    "directory": "packages/core"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "oxlint",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "prepack": "node -e \"require('fs').copyFileSync('../../LICENSE', 'LICENSE')\"",
    "postpack": "node -e \"require('fs').rmSync('LICENSE', { force: true })\""
  },
  "dependencies": {
    "@ai-billing/core": "workspace:*",
    "@openrouter/ai-sdk-provider": "^2.3.3"
  },
  "devDependencies": {
    "@ai-billing/typescript-config": "workspace:*",
    "@ai-billing/testing": "workspace:*",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "@ai-sdk/provider": "catalog:",
    "ai": "catalog:",
    "@edge-runtime/vm": "catalog:"
  },
  "peerDependencies": {
    "@ai-sdk/provider": "catalog:"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

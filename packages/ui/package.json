{
  "name": "@ai-billing/ui",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/narevai/ai-billing.git",
    "directory": "packages/ui"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./top-up": {
      "import": {
        "types": "./dist/top-up.d.ts",
        "default": "./dist/top-up.js"
      },
      "require": {
        "types": "./dist/top-up.d.cts",
        "default": "./dist/top-up.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "oxlint",
    "dev": "tsup --watch",
    "prepack": "node -e \"require('fs').copyFileSync('../../LICENSE', 'LICENSE')\"",
    "postpack": "node -e \"require('fs').rmSync('LICENSE', { force: true })\""
  },
  "dependencies": {},
  "devDependencies": {
    "@ai-billing/typescript-config": "workspace:*",
    "@types/react": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "oxlint": "catalog:"
  },
  "peerDependencies": {
    "@polar-sh/sdk": "^0.46.7",
    "react": "^18 || ^19",
    "stripe": "^21.0.0"
  },
  "peerDependenciesMeta": {
    "@polar-sh/sdk": {
      "optional": true
    },
    "stripe": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

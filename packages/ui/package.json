{
  "name": "@ai-billing/ui",
  "version": "0.0.7",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/narevai/ai-billing.git",
    "directory": "packages/ui"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "oxlint",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs:generate": "typedoc --options typedoc.json",
    "prepack": "node -e \"require('fs').copyFileSync('../../LICENSE', 'LICENSE')\"",
    "postpack": "node -e \"require('fs').rmSync('LICENSE', { force: true })\""
  },
  "dependencies": {
    "@ai-billing/types": "workspace:*",
    "markdown-to-jsx": "^9.8.1"
  },
  "devDependencies": {
    "@ai-billing/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "oxlint": "catalog:",
    "typedoc": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": "^18 || ^19"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

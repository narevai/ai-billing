{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "plugins": ["typescript"],
  "categories": {
    "correctness": "warn",
    "suspicious": "warn"
  },
  "rules": {
    "@typescript-eslint/no-explicit-any": "error"
  },
  "ignorePatterns": ["**/dist/**", "**/coverage/**"]
}

    "knip": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "tsup": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "mermaid": ">=11.15.0",
      "postcss": ">=8.5.10",
      "undici": ">=6.24.0",
      "uuid": ">=14.0.0"
    }
  }

    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check-types": "turbo run check-types",
    "knip": "turbo run //#knip:check",
    "knip:check": "knip",
    "storybook": "turbo run dev --filter=ai-billing-storybook",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "test:coverage": "turbo run test --filter=\"./packages/*\" -- --coverage"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint-plugin-jsdoc": "catalog:",
    "eslint-plugin-tsdoc": "catalog:",
    "knip": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "tsup": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "@opentelemetry/core": ">=2.8.0",
      "@opentelemetry/resources": ">=2.8.0",
      "dompurify": ">=3.4.11",
      "markdown-it": ">=14.2.0",
      "mermaid": ">=11.15.0",
      "postcss": ">=8.5.10",

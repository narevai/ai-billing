{
  "name": "ai-billing-monorepo",
  "packageManager": "pnpm@10.34.3+sha512.f2c531b08829d7be7f03c90addc266615f9c5477463e4bf1d275cb263ce9ea57cf0d5599110d94649a9bb3fed9f0b5efcea74a7016b61532a24cb9ad87860c1d",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "docs": "turbo run docs:generate --filter=docs",
    "lint": "turbo run lint",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check-types": "turbo run check-types",
    "knip": "turbo run //#knip:check",
    "knip:check": "knip",
    "storybook": "turbo run dev --filter=ai-billing-storybook",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "test:coverage": "turbo run test --filter=\"./packages/*\" -- --coverage"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint-plugin-jsdoc": "catalog:",
    "eslint-plugin-tsdoc": "catalog:",
    "knip": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "tsup": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "@opentelemetry/core": ">=2.8.0",
      "@opentelemetry/resources": ">=2.8.0",
      "dompurify": ">=3.4.7",
      "markdown-it": ">=14.2.0",
      "mermaid": ">=11.15.0",
      "postcss": ">=8.5.10",
      "undici": ">=6.24.0",
      "uuid": ">=14.0.0"
    }
  }
}

# Required: OpenAI API key for the chat model
OPENAI_API_KEY=sk-***

# Required: Polar.sh access token for billing
# https://polar.sh — use 'sandbox' or 'production'
POLAR_ACCESS_TOKEN=***

# Optional: Polar server environment (defaults to 'sandbox')
# POLAR_SERVER=sandbox

# Required: Narev API key for pricing and credit management
# https://narev.ai
NAREV_API_KEY=***
